# Dependencias
node_modules/

# Variables de entorno (credenciales)
.env
.env.local
.env.*.local

# Logs (incluye stdout/stderr del servicio Windows)
logs/
*.log
npm-debug.log*

# Sistema operativo
Thumbs.db
Desktop.ini
.DS_Store

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Datos locales de desarrollo (salidas en archivo JSON)
data/salidas.json
# Datos runtime que el servidor escribe constantemente y autocrea si no existen.
# Los dejamos sin trackear para no bloquear cambios de rama (`git checkout`).
data/analytics-events.json
data/historico-cambios.json
# Volcados de macros VBA generados por scripts (regenerables)
data/*.vba.txt

# Temporales
tmp/
temp/
*.tmp
.cache/

# Cobertura / pruebas
coverage/
.nyc_output/

# Build (si agregas bundler después)
dist/
build/
