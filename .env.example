# Copiar a .env y completar valores reales.
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env  (Windows cmd)

# --- PostgreSQL (obligatorio) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=nombre_bd
POSTGRES_USER=usuario
POSTGRES_PASSWORD=clave
POSTGRES_PORT=5432

# --- Servidor HTTP ---
PORT=8080
# 0 o false = desactivar compresión gzip (respuestas API y estáticos mayores al umbral interno).
HTTP_COMPRESSION=1

# --- Salidas / despachos ---
# 1 = leer y guardar en data/salidas.json (crea el archivo si no existe)
# 0 = usar tabla colbeef.salidas_cava (ejecutar scripts/db:salidas-schema si aplica)
SALIDAS_USE_FILE=1

# --- Histórico de auditoría (cambios en planillaje, etc.) ---
# Vacío o 0 = usar PostgreSQL (tabla app_auditoria_cambios; ejecutar npm run db:auditoria-schema si aplica)
# 1 = forzar data/historico-cambios.json (misma app, sin INSERT en BD)
AUDITORIA_USE_FILE=0

# --- Rendimiento BD ---
PG_STATEMENT_TIMEOUT=90s
PG_POOL_MAX=6
# Pool secundario (misma BD); opcional. Las consultas de librillos/guía usan `pool` y tablas directas.
PG_VISTA_POOL_MAX=4
PG_CONNECT_TIMEOUT_MS=
PG_VISTA_CONNECT_TIMEOUT_MS=
# Lotes para metadatos raíz + cava (solo tablas). Preferir nombre nuevo:
META_RAIZ_BATCH_SIZE=35
META_RAIZ_CONCURRENCY=3
# Alias heredado (equivale a META_RAIZ_* si los nuevos están vacíos):
# VISTA_CHUNK_SIZE=35
# VISTA_CHUNK_CONCURRENCY=3
CACHE_POLL_INTERVAL_MS=120000
# Caché en memoria por fecha (ms). Misma fecha repetida = respuesta rápida (defecto 90s).
CACHE_FECHA_MS=180000
# Lotes metadatos (propietario, sucursal, cava). Subir si la BD aguanta; bajar si hay timeouts.
# META_RAIZ_BATCH_SIZE=120
# META_RAIZ_CONCURRENCY=4
COLBEEF_DEBUG=0

# --- Operación (frontend + API validación) ---
HORA_CORTE_TURNO_SALIDA_BOGOTA=6
# Tipo de parte Colbeef en parte_producto (librillos / vísceras blancas)
ID_TIPO_PARTE_COLBEEF=14

# Columnas en a_plan_faena_producto con texto plan (opcional). Vacío = solo observaciones de parte.
# PLAN_FAENA_PFP_TEXT_COLUMNS=visceras_blancas,visceras_rojas
# plan_first | merge | parte_first
# PLAN_FAENA_OBS_PRIORIDAD=plan_first

# Universo del día: 1 = plan faena ∪ parte ese día (más cercano al Excel) | 0 = según configuración actual del servicio
USE_UNION_PARTE_PLAN_DIA=0

# 1 = listado solo plan ∩ insensibilizacion (solo ya sacrificados ese día)
# 0 o omitir = todo el plan del día (clasifica al cargar; cuadro Totales como antes)
# REQUIERE_INSENSIBILIZACION_PLAN_FAENA=1

# Sacrificio de emergencia: insens ese día en puesto emergencia entran al listado aunque el plan sea otro día
INCLUIR_SACRIFICIO_EMERGENCIA=1
# JOIN insensibilizacion.id_puesto_trabajo → catálogo (ajustar si el DBA usa otro nombre)
SACRIFICIO_EMERGENCIA_PUESTO_TABLA=trazabilidad_proceso.puesto_trabajo
SACRIFICIO_EMERGENCIA_PUESTO_COLUMNAS=nombre,descripcion
SACRIFICIO_EMERGENCIA_PUESTO_ILIKE=%sacrificio%emergencia%

# Resumen macro (/api/... resumen): 0 = contar por agrupacion_codigo real | 1 = en resumen solo, asurcarnes+pendiente parte → cocidos
# RESUMEN_RECODIFICAR_ASUR_PENDIENTE_A_COCIDOS=0
# Resumen macro: 0 = mismo universo que el plan (incl. sin parte ese día) | 1 = solo filas con parte tipo 14 ese día
RESUMEN_SOLO_PARTE_DIA=0

# Solo si tiene archivos PlanFaena*.xls / RETIRO*.xlsm en data/ y Python instalado
USE_LOCAL_PLAN_FILES=0
USE_LOCAL_RETIRO_FILES=0

# --- Analítica de uso (privado) ---
# Clave para consultar resumen de uso: GET /api/analytics/resumen-admin?key=...
# Si queda vacía, solo responde desde localhost.
ANALYTICS_ADMIN_KEY=123456789
